# Canvas LMS instance URL (required)
CANVAS_URL=https://q.utoronto.ca

# Canvas API token (required — generate at Canvas > Account > Settings > New Access Token)
# Stored in OS keychain after `quercus auth login`. Only use this env var for CI/headless.
CANVAS_TOKEN=

# MCP server port (optional, for HTTP transport)
QUERCUS_MCP_PORT=7878

# Sync directory for course files (optional, default: ~/School)
QUERCUS_SYNC_DIR=

# Cache database path (optional, default: ~/.cache/quercus/cache.db)
QUERCUS_CACHE_DIR=
