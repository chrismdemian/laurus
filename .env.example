# Canvas LMS instance URL (required)
CANVAS_URL=https://q.utoronto.ca

# Canvas API token (required — generate at Canvas > Account > Settings > New Access Token)
# Stored in OS keychain after `laurus setup`. Only use this env var for CI/headless.
CANVAS_TOKEN=

# Opt in to GraphQL for selected read operations (default: off; REST is faster on Quercus)
LAURUS_ENABLE_GRAPHQL=

# Kill switch to force REST even when GraphQL is enabled
LAURUS_DISABLE_GRAPHQL=
